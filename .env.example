# ─────────────────────────────────────────
#  POLYGON.IO
# ─────────────────────────────────────────
POLYGON_API_KEY=your_polygon_api_key_here

# ─────────────────────────────────────────
#  OANDA
# ─────────────────────────────────────────
OANDA_API_KEY=your_oanda_api_key_here
OANDA_ACCOUNT_ID=your_oanda_account_id_here
OANDA_ENVIRONMENT=practice          # practice | live

# ─────────────────────────────────────────
#  ENGINE MODE
# ─────────────────────────────────────────
TRADE_MODE=simulation               # simulation | live
LOG_LEVEL=INFO

# TELEGRAM NOTIFICATIONS
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
# Pakistan / blocked regions: route Python (not browser) through local VPN proxy:
# TELEGRAM_PROXY=socks5://127.0.0.1:10808
# TELEGRAM_PROXY=http://127.0.0.1:7890
# TELEGRAM_PROXY=http://user:pass@host:port
# Test: python scripts/test_telegram_proxy.py

# ─────────────────────────────────────────
#  RISK SETTINGS
# ─────────────────────────────────────────
DEFAULT_UNITS=1000                  # position size per trade
MAX_OPEN_TRADES=3
